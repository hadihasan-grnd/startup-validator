import streamlit as st
import faiss
import pandas as pd
from sentence_transformers import SentenceTransformer


df = pd.read_csv(
    "data/clean_startups.csv"
)

model = SentenceTransformer(
    "all-MiniLM-L6-v2"
)

index = faiss.read_index(
    "models/startup_index.faiss"
)

def search_startups(idea):

    query = model.encode([idea])

    faiss.normalize_L2(query)

    scores, indices = index.search(
        query,
        k=5
    )

    results = []

    for score, idx in zip(
        scores[0],
        indices[0]
    ):

        results.append({
            "name":
            df.iloc[idx]["Company Name"],

            "industry":
            df.iloc[idx]["Industry"],

            "score":
            round(float(score)*100,2)
        })

    return results

st.title(
    "Startup Idea Validator"
)

idea = st.text_area(
    "Enter Startup Idea"
)

if st.button("Analyze"):

    results = search_startups(
        idea
    )

    st.write(results)
